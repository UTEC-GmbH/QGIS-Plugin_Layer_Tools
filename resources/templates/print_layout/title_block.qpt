       <Option name="expression" type="QString" value="with_variable('lenpf', length(@project_filename),&#xd;&#xa;with_variable('maxlen_filename', 39,&#xd;&#xa;with_variable('min', 25,&#xd;&#xa;with_variable('shrink_max', 75,&#xd;&#xa;    if(@lenpf > @min AND @lenpf &lt;= @maxlen_filename,&#xd;&#xa;        clamp(&#xd;&#xa;&#x9;&#x9;&#x9;@shrink_max, &#xd;&#xa;&#x9;&#x9;&#x9;100 - (@lenpf - @min) * (100 - @shrink_max) / (@maxlen_filename - @min), &#xd;&#xa;&#x9;&#x9;&#x9;100&#xd;&#xa;&#x9;&#x9;),&#xd;&#xa;&#x9;&#x9;100&#xd;&#xa;    )&#xd;&#xa;))))"/>
